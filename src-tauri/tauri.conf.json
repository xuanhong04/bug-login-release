{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BugLogin",
  "version": "0.17.0",
  "identifier": "com.buglogin.desktop",
  "build": {
    "beforeDevCommand": "node scripts/tauri-before-dev.mjs",
    "devUrl": "http://localhost:12341",
    "beforeBuildCommand": "pnpm copy-proxy-binary && (node -e \"if(process.env.CI) process.exit(0); else process.exit(1)\" || pnpm build)",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "deb", "rpm", "appimage"],
    "category": "Productivity",
    "externalBin": ["binaries/buglogin-proxy", "binaries/buglogin-daemon"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": "entitlements.plist",
      "files": {
        "Info.plist": "Info.plist"
      }
    },
    "linux": {
      "deb": {
        "desktopTemplate": "buglogin.desktop",
        "depends": ["xdg-utils"]
      },
      "rpm": {
        "desktopTemplate": "buglogin.desktop",
        "depends": ["xdg-utils"]
      },
      "appimage": {
        "files": {
          "usr/share/applications/BugLogin.desktop": "buglogin-appimage.desktop",
          "usr/share/icons/hicolor/32x32/apps/buglogin.png": "icons/32x32.png",
          "usr/share/icons/hicolor/128x128/apps/buglogin.png": "icons/128x128.png",
          "usr/share/icons/hicolor/256x256/apps/buglogin.png": "icons/128x128@2x.png",
          "usr/share/icons/hicolor/512x512/apps/buglogin.png": "icons/icon.png",
          "usr/share/icons/hicolor/32x32/apps/BugLogin.png": "icons/32x32.png",
          "usr/share/icons/hicolor/128x128/apps/BugLogin.png": "icons/128x128.png",
          "usr/share/icons/hicolor/256x256/apps/BugLogin.png": "icons/128x128@2x.png",
          "usr/share/icons/hicolor/512x512/apps/BugLogin.png": "icons/icon.png",
          "usr/share/pixmaps/buglogin.png": "icons/icon.png",
          "usr/share/pixmaps/BugLogin.png": "icons/icon.png"
        }
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["http", "https", "buglogin"]
      }
    }
  }
}
